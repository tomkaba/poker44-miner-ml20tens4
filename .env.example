# Poker44 Miner Configuration
# Copy this file to .env and fill in your values
# Environment variables can also be set directly on the command line

# Bittensor wallet configuration
WALLET_NAME=my_cold
HOTKEY=my_poker44_hotkey

# Miner axon port (must be publicly accessible)
AXON_PORT=8091

# Optional: Whitelist of validator hotkeys (space or comma separated)
# If empty, falls back to --blacklist.force_validator_permit
ALLOWED_VALIDATOR_HOTKEYS=5GgnyzhZ6ozkdnQumwRuEaULggvMr2np4SS3N7eDCMMrXoMC 5FZD47WhA1UaVicYAr7pGnWb2YQLMD7uViipDYN2r1AJ5ggD

# Subtensor network (mainnet, testnet, finney, local)
SUBTENSOR_NETWORK=finney

# Optional: Netuid (default: 126 for Poker44)
NETUID=126

# Optional: Disable full logging of request payloads
# POKER44_DISABLE_FULL_LOGS=false
